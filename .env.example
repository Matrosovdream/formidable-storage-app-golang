APP_NAME=FormidableStorageApp
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_PORT=8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgx
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=app
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_SSLMODE=disable

REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_DB=0

CACHE_SERVICE_DRIVER=redis
CACHE_SERVICE_TTL=3600
CACHE_SERVICE_PREFIX=fsa:

QUEUE_CONNECTION=redis
QUEUE_STREAM=queues:default
QUEUE_STATS_KEY=queue-stats

SESSION_LIFETIME=120
TOKEN_LIFETIME=0
BCRYPT_ROUNDS=12

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME=FormidableStorageApp
