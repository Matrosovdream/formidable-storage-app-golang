.git
.gitignore
.dockerignore
.env
.env.*
!.env.example

# IDE / OS
.vscode
.idea
.DS_Store
*.swp

# Build artefacts
bin/
tmp/
*.log
# Stray compiled binaries at repo root (e.g. `./seed` from `go build`)
/seed
/web
/worker
*.exe

# Sub-trees we never want copied into the image
project-reference/
project-plan/
.claude/

# Tests / docs that don't belong in image
test/
*.md
!README.md
